# OpenKB GUI Configuration Example
# ============================================================
# Copy this file to .env and fill in your API keys

# LLM Configuration (canonical)
# Model format: provider/model-name
# Examples:
#   - Z.ai: zai/glm-4.5-flash, zai/glm-4-plus
#   - OpenRouter: openrouter/deepseek/deepseek-chat, openrouter/meta-llama/llama-3.1-8b-instruct
LLM_MODEL=zai/glm-4.5-flash
LLM_API_KEY=
LLM_API_BASE=

# Provider-specific API Keys (optional fallback to LLM_API_KEY for selected provider)
# Z.ai (智谱) - Get your key at: https://open.bigmodel.cn/
ZAI_API_KEY=

# OpenRouter - Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# PageIndex OCR (optional - for PDF scans and long documents)
PAGEINDEX_API_KEY=

# Workspace Settings
WORKSPACE_PATH=./workspace

# Watch Mode Settings
WATCH_ENABLED=true
WATCH_DEBOUNCE_SECONDS=2

# Logging
LOG_LEVEL=INFO
