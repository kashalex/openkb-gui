# OpenKB GUI Configuration
# Copy this file to .env and fill in your values

# ============================================================
# LLM Configuration (REQUIRED)
# ============================================================
# API Key for your LLM provider
# For Zhipu AI: Get your key at https://open.bigmodel.cn/
LLM_API_KEY=your_api_key_here

# Model in LiteLLM format: provider/model-name
# Examples:
#   - Zhipu AI: zhipu/glm-4-flash, zhipu/glm-4
#   - OpenAI: openai/gpt-4, openai/gpt-3.5-turbo
#   - Anthropic: anthropic/claude-3-sonnet
#   - Custom endpoint: openai/your-model-name (with OPENAI_API_BASE set)
LLM_MODEL=zhipu/glm-4-flash

# API Base URL (optional, for custom endpoints)
# Leave empty for default provider endpoints
# For Zhipu AI: https://open.bigmodel.cn/api/paas/v4
LLM_API_BASE=

# ============================================================
# GUI Settings (optional)
# ============================================================
# OpenAI-compatible settings (used by GUI for some features)
OPENAI_MODEL=openai/glm-4-flash
OPENAI_API_BASE=https://open.bigmodel.cn/api/paas/v4
OPENAI_API_KEY=your_api_key_here

# PageIndex OCR (optional - for PDF scans and long documents)
PAGEINDEX_API_KEY=

# Workspace path
WORKSPACE_PATH=./workspace

# Watch mode
WATCH_ENABLED=true
WATCH_DEBOUNCE_SECONDS=2

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
