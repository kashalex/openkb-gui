# OpenKB GUI Configuration

# LLM Configuration (REQUIRED)
OPENAI_MODEL=openai/glm-4.7-flash
OPENAI_API_BASE=https://api.z.ai/api/paas/v4
OPENAI_API_KEY=

# PageIndex OCR (Optional - for PDF scans and long documents)
PAGEINDEX_API_KEY=

# Workspace Settings
WORKSPACE_PATH=./workspace

# Watch Mode Settings
WATCH_ENABLED=true
WATCH_DEBOUNCE_SECONDS=2

# Logging
LOG_LEVEL=INFO
