# OpenKB GUI Configuration
# ============================================================

# LLM Configuration (REQUIRED for OpenKB CLI)
# Model format: provider/model-name
# Examples:
#   - Zhipu AI: zhipu/glm-4-flash, zhipu/glm-4
#   - OpenAI: openai/gpt-4o, openai/gpt-3.5-turbo
#   - Anthropic: anthropic/claude-3-sonnet
#   - DeepSeek: deepseek/deepseek-chat
LLM_MODEL=zhipu/glm-4-flash
LLM_API_KEY=your_api_key_here
LLM_API_BASE=

# GUI Settings (also used by some features)
OPENAI_MODEL=zhipu/glm-4-flash
OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE=

# PageIndex OCR (optional - for PDF scans and long documents)
PAGEINDEX_API_KEY=

# Workspace Settings
WORKSPACE_PATH=./workspace

# Watch Mode Settings
WATCH_ENABLED=true
WATCH_DEBOUNCE_SECONDS=2

# Logging
LOG_LEVEL=INFO
